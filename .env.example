# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Chatwoot
CHATWOOT_API_URL=https://your-chatwoot.com/api/v1/accounts/1
CHATWOOT_API_TOKEN=your_chatwoot_token_here

# n8n media proxy (para servir imagenes/videos desde Drive)
NEXT_PUBLIC_N8N_MEDIA_PROXY_URL=https://your-n8n.com/webhook/f7-media

# Seed endpoint (solo para poblar contactos ficticios una vez)
SEED_SECRET=cambiar-por-algo-random
